# Copy this file to `.env` and fill in the values from your Supabase project
# (Dashboard -> Project Settings -> API). Both are client-safe (exposed to the browser).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# DO NOT put server-only secrets here. The service-role key and any LLM
# provider keys must never reach the client.
#   - SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected into Edge Functions.
#   - LLM keys are set as Edge Function secrets, e.g.:
#       npx supabase secrets set OPENAI_API_KEY=sk-...
